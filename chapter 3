#Bài 14:
def count_vowels(s):
    vowels = "aeiou"
    return sum(1 for char in s.lower() if char in vowels)

chuoi = input("Nhập chuỗi cần đếm nguyên âm: ")
print(f"Số lượng nguyên âm: {count_vowels(chuoi)}")


#BÀi 5:
data = list(map(float, input("Nhập danh sách số thực (cách nhau bởi dấu cách): ").split()))

for i in range(1, len(data)):
    key = data[i]
    j = i - 1
    while j >= 0 and data[j] < key:
        data[j + 1] = data[j]
        j -= 1
    data[j + 1] = key

print("Danh sách sau khi sắp xếp giảm dần:", data)

#Bài 6:
nums = list(map(int, input("Nhập danh sách số nguyên: ").split()))
swaps = 0
n = len(nums)

for i in range(n):
    for j in range(0, n - i - 1):
        if nums[j] > nums[j + 1]:
            nums[j], nums[j + 1] = nums[j + 1], nums[j]
            swaps += 1

print("Danh sách đã sắp xếp:", nums)
print("Số lần hoán đổi:", swaps)


m = int(input("Nhập số hàng m: "))
n = int(input("Nhập số cột n: "))

def input_matrix(name):
    print(f"Nhập ma trận {name}:")
    matrix = []
    for i in range(m):
        row = list(map(int, input(f"Hàng {i+1}: ").split()))
        matrix.append(row)
    return matrix

A = input_matrix("A")
B = input_matrix("B")

result = [[A[i][j] + B[i][j] for j in range(n)] for i in range(m)]

print("Ma trận tổng:")
for row in result:
    print(row)


Bài 14:
n = int(input("Nhập số n cần kiểm tra: "))
if n <= 1:
    print(f"{n} không phải là số nguyên tố.")
else:
    dem_uoc = 0
    for i in range(1, n + 1):
        if n % i == 0:
            dem_uoc += 1
    if dem_uoc == 2:
        print(f"{n} là số nguyên tố.")
    else:
        print(f"{n} không phải là số nguyên tố.")


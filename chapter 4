#Bài 1:
def thong_ke_tuple(numbers):
    if not numbers:
        return 0, None, None

    tong = sum(numbers)
    lon_nhat = max(numbers)
    nho_nhat = min(numbers)

    return tong, lon_nhat, nho_nhat


# VD
my_tuple = (10, 25, 5, 40, 15)
tong, max_val, min_val = thong_ke_tuple(my_tuple)

print(f"Tổng: {tong}")
print(f"Lớn nhất: {max_val}")
print(f"Nhỏ nhất: {min_val}")

#bài 2:
def tinh_diem_trung_binh(danh_sach_diem):
    if not danh_sach_diem:
        return 0

    tong_diem = sum(danh_sach_diem.values())
    so_luong = len(danh_sach_diem)

    return tong_diem / so_luong


# VD
sinh_vien = {"An": 8.5, "Bình": 7.0, "Chi": 9.0}
dtb = tinh_diem_trung_binh(sinh_vien)
print(f"Điểm trung bình của {len(sinh_vien)} sinh viên là: {dtb:.2f}")


#Bài 3:
def kiem_tra_key(dictionary, key):
    if key in dictionary:
        print(f"Key '{key}' có tồn tại trong dictionary.")
    else:
        print(f"Key '{key}' không tồn tại.")

# VD
data = {"brand": "Ford", "model": "Mustang", "year": 1964}
kiem_tra_key(data, "model")
kiem_tra_key(data, "color")


#BÀi 5:
class Product:
    def __init__(self, name, price):
        self.name = name
        self._price = price if price > 0 else 0

    def price(self):
        return self._price

    def price(self, value):
        if value > 0:
            self._price = value
        else:
            print("Lỗi: Giá sản phẩm phải lớn hơn 0!")

    def __str__(self):
        return f"Sản phẩm: {self.name} - Giá: {self._price}"

# Thử nghiệm
sp = Product("Laptop", 1500)
print(sp)

sp.price = 2000
sp.price = -500
print(sp)
